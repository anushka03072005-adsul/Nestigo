# ========== ENVIRONMENT ==========
NODE_ENV=development

# ========== SESSION ==========
# Generate secure secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-secure-session-secret-here

# ========== CLOUDINARY (Image Storage) ==========
CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

# ========== DATABASE ==========
# For Local Development
MONGO_URL=mongodb://localhost:27017/nestigo

# For MongoDB Atlas (Production/Firebase)
ATLAS_URL=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ========== GEOCODING (Location Services) ==========
# Get free key from https://opencagedata.com/
GEOCODING_API_KEY=your-opencage-api-key

# ========== FIREBASE (Deployment) ==========
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ========== NODE.JS Settings ==========
PORT=8080
